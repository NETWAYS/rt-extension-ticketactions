%# Quick action icon bar for the ticket display page. Mirrors the ticket
%# "Actions" menu (reply/comment/forward, lifecycle transitions, take/steal)
%# and adds the NETWAYS QuickResolve/QuickStall/Follow-up entries.
%#
%# The button set is rendered by the RT-Extension-TicketActions-QuickAccess
%# element and re-fetched in place on status/owner/date changes, so it stays
%# current after an inline (htmx) quick action.
%#
%# Add this widget to the ticket display page via Admin -> Page Layouts
%# (class RT::Ticket, page Display).
% $m->callback( %ARGS, CallbackName => 'BeforeWidget' );
<&| /Widgets/TitleBox, title => loc('Quick Actions'), class => 'ticket-info-basics' &>
  <div hx-trigger="ticketStatusChanged from:body, ticketOwnerChanged from:body, ticketDatesChanged from:body"
       hx-get="<% RT->Config->Get('WebPath') %>/Views/Ticket/Elements/RT-Extension-TicketActions-QuickAccess?id=<% $TicketObj->id %>"
       hx-swap="innerHTML">
    <& /Ticket/Elements/RT-Extension-TicketActions-QuickAccess, Ticket => $TicketObj &>
  </div>
</&>
% $m->callback( %ARGS, CallbackName => 'AfterWidget' );
<%ARGS>
$TicketObj
</%ARGS>
<%METHOD PreCheck>
<%args>
$Object
</%args>
<%init>
return 1
    if $Object->CurrentUserHasRight('ModifyTicket')
    || $Object->CurrentUserHasRight('ReplyToTicket')
    || $Object->CurrentUserHasRight('CommentOnTicket');
return 0;
</%init>
</%METHOD>
