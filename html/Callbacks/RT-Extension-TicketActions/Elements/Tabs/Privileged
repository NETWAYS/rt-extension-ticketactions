<%init>
my $actions = PageMenu()->child('actions');
return unless $actions;

# RT6 passes the real page path as the Path argument and exposes the page's
# arguments via $DECODED_ARGS (the page menu is rebuilt in the lazy
# /Views/Component/PageMenu request, where $r->path_info and the callback
# ARGSRef do not carry the ticket path/id).
return unless ( $Path || '' ) =~ m{^/Ticket/};

my $id = $HTML::Mason::Commands::DECODED_ARGS->{'id'};
return unless ( ( $id // '' ) =~ /^(\d+)$/ );
$id = $1;

my $ticket = RT::Ticket->new( $session{'CurrentUser'} );
$ticket->Load($id);
return unless $ticket->Id;

# Add the NETWAYS QuickResolve/QuickStall/Follow-up entries to the ticket
# "Actions" menu. The same entries are rendered as icons by the
# /Ticket/Widgets/Display/TicketActions display widget.
for my $entry ( RT::Extension::TicketActions::FollowUpActions($ticket) ) {
    $actions->child( $entry->{key}, title => $entry->{title}, path => $entry->{path} );
}
</%init>
<%args>
$Path => undef
</%args>
